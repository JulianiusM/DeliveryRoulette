extends ../layout

block meta
    title Providers | DeliveryRoulette

block body
    - const maintenance = data.maintenance || {}
    - const providers = data.providers || []
    - const discoveryCount = providers.filter((provider) => provider.capabilities.canDiscoverFromListingUrl).length
    - const importCount = providers.filter((provider) => provider.capabilities.canImportFromUrl).length

    .app-shell.py-3
        section.card.border-0.shadow-lg.overflow-hidden.app-hero-card.is-warning
            .card-body.p-4.p-lg-5
                .row.g-4.align-items-end
                    .col-lg-8
                        p.app-eyebrow.mb-2 Provider operations
                        h1.display-5.fw-semibold.mb-2 Providers
                        p.lead.text-white-50.mb-0 Configure discovery and direct imports, then use maintenance actions when provider schemas or menu data change.
                    .col-lg-4
                        .row.g-3
                            .col-4
                                .app-stat-card
                                    span.app-stat-label Connectors
                                    strong.app-stat-value #{providers.length}
                                    small.text-white-50 Registered provider integrations
                            .col-4
                                .app-stat-card
                                    span.app-stat-label Discovery
                                    strong.app-stat-value #{discoveryCount}
                                    small.text-white-50 Listing-based discovery connectors
                            .col-4
                                .app-stat-card
                                    span.app-stat-label Direct import
                                    strong.app-stat-value #{importCount}
                                    small.text-white-50 Restaurant URL imports available
                .app-chip-row.mt-4
                    a.btn.btn-outline-light.btn-sm(href="/sync/jobs")
                        i.bi.bi-list-check.me-1
                        | View Sync Jobs
                    a.btn.btn-outline-light.btn-sm(href="/sync/alerts")
                        i.bi.bi-bell.me-1
                        | View Sync Alerts

        section.card.app-section-card
            .card-header
                i.bi.bi-tools.me-2
                | Maintenance
            .card-body
                .row.g-4
                    .col-lg-6
                        .app-panel.app-provider-maintenance-card.h-100
                            .app-chip-row
                                span.app-chip
                                    i.bi.bi-cpu
                                    | Heuristic refresh #{maintenance.heuristicRefreshRunning ? 'running' : 'idle'}
                            div
                                h2.h5.mb-2 Re-run All Heuristics
                                p.text-white-50.small.mb-0 Refresh stored inference results for all restaurants after scoring or keyword engine changes.
                            form.mt-auto(method="POST" action="/providers/maintenance/heuristics")
                                +csrf
                                button.btn.btn-outline-info(type="submit" disabled=maintenance.heuristicRefreshRunning)
                                    i.bi.bi-cpu.me-1
                                    | #{maintenance.heuristicRefreshRunning ? 'Heuristic Refresh Running' : 'Re-run All Heuristics'}
                    .col-lg-6
                        .app-panel.app-provider-maintenance-card.h-100
                            .app-chip-row
                                span.app-chip
                                    i.bi.bi-arrow-repeat
                                    | Provider refresh version #{maintenance.providerRefreshVersion || 'n/a'}
                            div
                                h2.h5.mb-2 Reimport Provider Data
                                p.text-white-50.small.mb-0 Queue provider-backed restaurant refreshes again when connector parsing, mapping, or upstream data shape changes.
                            form.mt-auto(method="POST" action="/providers/maintenance/reimport")
                                +csrf
                                button.btn.btn-outline-success(type="submit")
                                    i.bi.bi-arrow-repeat.me-1
                                    | Reimport Provider Data
                .app-status-card.is-info.mt-4
                    .d-flex.align-items-start.gap-3
                        i.bi.bi-info-circle.fs-4
                        div
                            h2.h6.text-uppercase.text-white-50.mb-2 Operational note
                            p.text-white-50.mb-0 Startup maintenance already handles stale heuristic results and refresh-version driven reimports automatically. Use these actions when you need an explicit rerun.

        if providers.length === 0
            .app-empty-state
                i.bi.bi-plug
                p.mb-0 No provider connectors with configurable options are currently registered.
        else
            section.card.app-section-card
                .card-header.d-flex.justify-content-between.align-items-center.flex-wrap.gap-2
                    span
                        i.bi.bi-plug.me-2
                        | Provider Directory
                    span.app-chip
                        i.bi.bi-collection.me-1
                        | #{providers.length} providers
                .card-body
                    .app-provider-search-meta.mb-4
                        div
                            h2.h5.mb-1 Find A Provider
                            p.text-white-50.small.mb-0 Filter the directory by provider name, key, or supported workflow.
                        .input-group
                            span.input-group-text.text-bg-dark
                                i.bi.bi-search
                            input#providerSearch.form-control.text-bg-dark(type="search" placeholder="Search providers, imports, discovery..." autocomplete="off")
                    .app-chip-row.mb-4
                        span.app-chip
                            i.bi.bi-funnel.me-1
                            | Showing
                            strong#providerSearchCount #{providers.length} / #{providers.length}
                    #providerSearchEmpty.app-empty-state.d-none
                        i.bi.bi-search
                        p.mb-0 No providers match the current search.
                    #providerDirectory.d-flex.flex-column.gap-4
                        each provider in providers
                            - const providerSearchText = [provider.displayName, provider.providerKey, provider.capabilities.listingUrlLabel, provider.capabilities.importUrlLabel, provider.capabilities.canDiscoverFromListingUrl ? 'discovery listing sync delivery area' : '', provider.capabilities.canImportFromUrl ? 'direct import menu restaurant url' : ''].filter(Boolean).join(' ')
                            article.app-list-card(data-provider-card data-provider-search=providerSearchText)
                                .d-flex.justify-content-between.align-items-start.flex-wrap.gap-3.mb-3
                                    div
                                        h2.h4.mb-1 #{provider.displayName}
                                        p.text-white-50.small.mb-0 Key #{provider.providerKey}
                                    .app-chip-row
                                        if provider.capabilities.canDiscoverFromListingUrl
                                            span.app-chip Discovery enabled
                                        if provider.capabilities.canImportFromUrl
                                            span.app-chip Direct import enabled
                                .row.g-4
                                    if provider.capabilities.canDiscoverFromListingUrl
                                        .col-xl-6
                                            .app-panel.h-100
                                                h3.h5.mb-2
                                                    i.bi.bi-geo-alt.me-2
                                                    | Discovery From Listing URL
                                                p.text-white-50.small.mb-3 Paste a delivery area listing URL to discover restaurants for this provider.
                                                form(method="POST" action=`/providers/${provider.providerKey}/sync`)
                                                    +csrf
                                                    .mb-3
                                                        label.form-label(for=`listingUrl-${provider.providerKey}`)= provider.capabilities.listingUrlLabel || 'Listing URL'
                                                        input.form-control.text-bg-dark.border-secondary(
                                                            type="url"
                                                            id=`listingUrl-${provider.providerKey}`
                                                            name="listingUrl"
                                                            placeholder=provider.capabilities.listingUrlPlaceholder || 'https://...'
                                                            value=provider.listingUrl
                                                            required
                                                        )
                                                    button.btn.btn-primary(type="submit")
                                                        i.bi.bi-arrow-repeat.me-1
                                                        | Sync Listing
                                    if provider.capabilities.canImportFromUrl
                                        .col-xl-6
                                            .app-panel.h-100
                                                h3.h5.mb-2
                                                    i.bi.bi-link-45deg.me-2
                                                    | Direct Restaurant Import
                                                p.text-white-50.small.mb-3 Paste a restaurant menu URL to import or refresh a single restaurant directly.
                                                form(method="POST" action=`/providers/${provider.providerKey}/import-url`)
                                                    +csrf
                                                    .mb-3
                                                        label.form-label(for=`menuUrl-${provider.providerKey}`)= provider.capabilities.importUrlLabel || 'Restaurant URL'
                                                        input.form-control.text-bg-dark.border-secondary(
                                                            type="url"
                                                            id=`menuUrl-${provider.providerKey}`
                                                            name="menuUrl"
                                                            placeholder=provider.capabilities.importUrlPlaceholder || 'https://...'
                                                            required
                                                        )
                                                    button.btn.btn-success(type="submit")
                                                        i.bi.bi-download.me-1
                                                        | Import Restaurant
                                    if !provider.capabilities.canDiscoverFromListingUrl && !provider.capabilities.canImportFromUrl
                                        .col-12
                                            .app-panel
                                                p.text-white-50.small.mb-0 This connector is registered but does not currently expose interactive sync or import actions on this page.

block scripts
    script(type="module" src="/js/modules/providers.gen.js")
