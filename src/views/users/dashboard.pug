extends ../layout

block meta
    title Dashboard | DeliveryRoulette

block body
    - const restaurantCount = (data && data.restaurantCount) || 0
    - const suggestionCount = (data && data.suggestionCount) || 0
    - const syncAlertCount = (data && data.syncAlertCount) || 0
    - const dietTagCount = (data && data.dietTagCount) || 0
    - const preferences = (data && data.preferences) || {}
    - const defaultLocation = preferences.defaultLocation || null
    - const hasStructuredLocation = !!(defaultLocation && (defaultLocation.label || defaultLocation.addressLine1 || defaultLocation.city || defaultLocation.postalCode || defaultLocation.country))
    - const displayName = user ? (user.displayName || user.name || user.username) : 'User'

    .app-shell.py-3
        section.card.border-0.shadow-lg.overflow-hidden.app-hero-card.is-success
            .card-body.p-4.p-lg-5
                .row.g-4.align-items-end
                    .col-lg-8
                        p.app-eyebrow.mb-2 Personal workspace
                        h1.display-5.fw-semibold.mb-2 Welcome, #{displayName}
                        p.lead.text-white-50.mb-0 Your defaults, favorites, and operational shortcuts live here. This is the fastest place to branch into restaurants, suggestions, imports, and sync follow-up.
                    .col-lg-4
                        .row.g-3
                            .col-6.col-xl-3.col-lg-6
                                .app-stat-card
                                    span.app-stat-label Restaurants
                                    strong.app-stat-value #{restaurantCount}
                            .col-6.col-xl-3.col-lg-6
                                .app-stat-card
                                    span.app-stat-label Suggestions
                                    strong.app-stat-value #{suggestionCount}
                            .col-6.col-xl-3.col-lg-6
                                .app-stat-card
                                    span.app-stat-label Diet tags
                                    strong.app-stat-value #{dietTagCount}
                            .col-6.col-xl-3.col-lg-6
                                .app-stat-card
                                    span.app-stat-label Alerts
                                    strong.app-stat-value #{syncAlertCount}
                                    small.text-white-50 #{syncAlertCount > 0 ? 'Needs review' : 'Clear'}

        section.card.app-section-card
            .card-header
                i.bi.bi-lightning-charge.me-2
                | Quick Actions
            .card-body
                .row.g-4
                    .col-md-6.col-xl-3
                        a.app-action-card(href="/restaurants")
                            .d-flex.align-items-center.gap-3
                                span.app-icon-badge.is-primary
                                    i.bi.bi-shop
                                div
                                    h2.h5.mb-1 Restaurants
                                    p.text-white-50.small.mb-0 Review visibility, providers, and menu quality.
                    .col-md-6.col-xl-3
                        a.app-action-card(href="/suggest")
                            .d-flex.align-items-center.gap-3
                                span.app-icon-badge.is-success
                                    i.bi.bi-shuffle
                                div
                                    h2.h5.mb-1 Suggest
                                    p.text-white-50.small.mb-0 Draw from your current defaults or refine the pool.
                    .col-md-6.col-xl-3
                        a.app-action-card(href="/users/settings")
                            .d-flex.align-items-center.gap-3
                                span.app-icon-badge.is-info
                                    i.bi.bi-gear-fill
                                div
                                    h2.h5.mb-1 Settings
                                    p.text-white-50.small.mb-0 Tune suggestion defaults and personal diet filters.
                    .col-md-6.col-xl-3
                        a.app-action-card(href="/providers")
                            .d-flex.align-items-center.gap-3
                                span.app-icon-badge.is-warning
                                    i.bi.bi-plug
                                div
                                    h2.h5.mb-1 Providers
                                    p.text-white-50.small.mb-0 Monitor imports, jobs, and refresh maintenance.

        section.card.app-section-card
            .card-header.d-flex.justify-content-between.align-items-center.flex-wrap.gap-2
                span
                    i.bi.bi-person-circle.me-2
                    | Your Defaults
                a.btn.btn-sm.btn-outline-light(href="/users/settings")
                    i.bi.bi-pencil.me-1
                    | Edit Settings
            .card-body
                if hasStructuredLocation || preferences.deliveryArea || preferences.cuisineIncludes || preferences.cuisineExcludes
                    .row.g-4
                        if hasStructuredLocation
                            .col-md-4
                                .app-panel.h-100
                                    h2.h6.text-uppercase.text-white-50.mb-2 Saved location
                                    p.mb-1 #{defaultLocation.label}
                                    - const locationSummaryParts = [defaultLocation.addressLine1, [defaultLocation.postalCode, defaultLocation.city].filter(Boolean).join(' '), defaultLocation.country].filter(Boolean)
                                    if locationSummaryParts.length
                                        p.text-white-50.small.mb-1 #{locationSummaryParts.join(' / ')}
                                    if defaultLocation.latitude !== '' && defaultLocation.longitude !== ''
                                        span.badge.rounded-pill.text-bg-success Coordinates set
                                    else
                                        span.badge.rounded-pill.text-bg-secondary Coordinates missing
                        else if preferences.deliveryArea
                            .col-md-4
                                .app-panel.h-100
                                    h2.h6.text-uppercase.text-white-50.mb-2 Delivery area
                                    p.mb-0 #{preferences.deliveryArea}
                        if preferences.cuisineIncludes
                            .col-md-4
                                .app-panel.h-100
                                    h2.h6.text-uppercase.text-white-50.mb-2 Preferred cuisines
                                    p.mb-0 #{preferences.cuisineIncludes}
                        if preferences.cuisineExcludes
                            .col-md-4
                                .app-panel.h-100
                                    h2.h6.text-uppercase.text-white-50.mb-2 Excluded cuisines
                                    p.mb-0 #{preferences.cuisineExcludes}
                else
                    .app-empty-state
                        i.bi.bi-sliders
                        p.mb-0 You have not saved personal suggestion defaults yet.
