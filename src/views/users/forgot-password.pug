extends ../layout

block meta
    title Password Reset | DeliveryRoulette

block body
    .app-shell.py-3
        section.card.border-0.shadow-lg.overflow-hidden.app-hero-card.is-warning
            .card-body.p-4.p-lg-5
                .row.g-4.align-items-end
                    .col-lg-8
                        p.app-eyebrow.mb-2 Account recovery
                        h1.display-5.fw-semibold.mb-2 Forgot Your Password?
                        p.lead.text-white-50.mb-0 Enter your username and the app will send a reset link to the configured account email.
                    .col-lg-4
                        .app-chip-row.justify-content-lg-end
                            span.app-chip Reset by username
                            span.app-chip Return to login after request

        section.card.app-section-card
            .card-body
                .row.g-4.justify-content-center
                    .col-xl-6
                        .app-panel.h-100
                            form#forgotForm.row.g-3(action="/users/forgot-password" method="post")
                                +csrf
                                .col-12
                                    label.form-label(for="username")
                                        i.bi.bi-person-circle.me-1
                                        | Username
                                    input#username.form-control.text-bg-dark(
                                        type="text"
                                        name="username"
                                        placeholder="Your username"
                                        required
                                    )
                                .col-12.d-flex.flex-wrap.gap-2
                                    button.btn.btn-success(type="submit")
                                        i.bi.bi-send-check.me-1
                                        | Send Reset Link
                                    a.btn.btn-outline-light(href="/users/login")
                                        i.bi.bi-arrow-left-circle.me-1
                                        | Back To Login
                    .col-xl-4
                        .app-panel.h-100
                            h2.h6.text-uppercase.text-white-50.mb-3 Notes
                            ul.text-white-50.small.mb-0
                                li Use the same username you sign in with.
                                li The reset flow does not expose whether an account exists.
                                li Once you receive the link, you can set a new password directly.
