extends ../layout

block meta
    title Reset Password | DeliveryRoulette

block body
    .app-shell.py-3
        section.card.border-0.shadow-lg.overflow-hidden.app-hero-card.is-warning
            .card-body.p-4.p-lg-5
                .row.g-4.align-items-end
                    .col-lg-8
                        p.app-eyebrow.mb-2 Account recovery
                        h1.display-5.fw-semibold.mb-2 Reset Your Password
                        p.lead.text-white-50.mb-0 Set a new password for the account linked to this reset token.
                    .col-lg-4
                        .app-chip-row.justify-content-lg-end
                            span.app-chip Minimum 8 characters
                            span.app-chip Token-bound reset

        section.card.app-section-card
            .card-body
                .row.g-4.justify-content-center
                    .col-xl-6
                        .app-panel.h-100
                            form.row.g-3(action=`/users/reset-password/${token}` method="post")
                                +csrf
                                .col-12
                                    label.form-label(for="password")
                                        i.bi.bi-key-fill.me-1
                                        | New password
                                    input#password.form-control.text-bg-dark(
                                        type="password"
                                        name="password"
                                        minlength="8"
                                        placeholder="min. 8 characters"
                                        required
                                    )
                                .col-12
                                    label.form-label(for="confirmPassword")
                                        i.bi.bi-key.me-1
                                        | Confirm password
                                    input#confirmPassword.form-control.text-bg-dark(
                                        type="password"
                                        name="confirmPassword"
                                        minlength="8"
                                        placeholder="repeat password"
                                        required
                                    )
                                .col-12.d-flex.flex-wrap.gap-2
                                    button.btn.btn-success(type="submit")
                                        i.bi.bi-check-lg.me-1
                                        | Change Password
                                    a.btn.btn-outline-light(href="/users/login")
                                        i.bi.bi-arrow-left-circle.me-1
                                        | Back To Login
                    .col-xl-4
                        .app-panel.h-100
                            h2.h6.text-uppercase.text-white-50.mb-3 Notes
                            ul.text-white-50.small.mb-0
                                li Choose a password that you are not already using elsewhere.
                                li Both fields must match before the change is accepted.
                                li After the reset, sign in through the normal login page.
