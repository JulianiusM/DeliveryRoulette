extends ../layout

block meta
    title Settings | DeliveryRoulette

block body
    - const d = data || {}
    - const selectedDietCount = (d.dietTags || []).filter((tag) => tag.selected).length

    .app-shell.py-3
        section.card.border-0.shadow-lg.overflow-hidden.app-hero-card.is-info
            .card-body.p-4.p-lg-5
                .row.g-4.align-items-end
                    .col-lg-8
                        p.app-eyebrow.mb-2 Personal defaults
                        h1.display-5.fw-semibold.mb-2 Settings
                        p.lead.text-white-50.mb-0 Set the defaults that should prefill the suggestion flow. These values are personal and only shape your own filters.
                    .col-lg-4
                        .row.g-3
                            .col-4
                                .app-stat-card
                                    span.app-stat-label Delivery area
                                    strong.app-stat-value #{d.deliveryArea ? 'Set' : '-'}
                            .col-4
                                .app-stat-card
                                    span.app-stat-label Diets
                                    strong.app-stat-value #{selectedDietCount}
                            .col-4
                                .app-stat-card
                                    span.app-stat-label Cuisines
                                    strong.app-stat-value #{[d.cuisineIncludes, d.cuisineExcludes].filter(Boolean).length}

        section.card.app-section-card
            .card-header.d-flex.justify-content-between.align-items-center.flex-wrap.gap-2
                span
                    i.bi.bi-gear-fill.me-2
                    | Suggestion Defaults
                a.btn.btn-sm.btn-outline-info(href="/users/settings/diets")
                    i.bi.bi-sliders.me-1
                    | Configure Global Diet Heuristics
            .card-body
                form(action="/users/settings" method="post")
                    +csrf
                    .row.g-4
                        .col-lg-6
                            .app-panel.h-100
                                h2.h5.mb-3
                                    i.bi.bi-compass.me-2
                                    | Location And Cuisine Defaults
                                .mb-3
                                    label.form-label(for="deliveryArea")
                                        i.bi.bi-geo-alt.me-1
                                        | Default Delivery Area
                                    input#deliveryArea.form-control.text-bg-dark(
                                        type="text"
                                        name="deliveryArea"
                                        maxlength="150"
                                        value=(d.deliveryArea || '')
                                        placeholder="e.g. Downtown, Midtown, 10km radius"
                                    )
                                .mb-3
                                    label.form-label(for="cuisineIncludes")
                                        i.bi.bi-hand-thumbs-up.me-1
                                        | Preferred Cuisines
                                    input#cuisineIncludes.form-control.text-bg-dark(
                                        type="text"
                                        name="cuisineIncludes"
                                        value=(d.cuisineIncludes || '')
                                        placeholder="e.g. Italian, Japanese, Mexican"
                                    )
                                    .form-text.text-white-50 Comma-separated list of cuisines to prefer.
                                .mb-0
                                    label.form-label(for="cuisineExcludes")
                                        i.bi.bi-hand-thumbs-down.me-1
                                        | Excluded Cuisines
                                    input#cuisineExcludes.form-control.text-bg-dark(
                                        type="text"
                                        name="cuisineExcludes"
                                        value=(d.cuisineExcludes || '')
                                        placeholder="e.g. Fast Food, Sushi"
                                    )
                                    .form-text.text-white-50 Comma-separated list of cuisines to exclude.
                        .col-lg-6
                            .app-panel.h-100
                                h2.h5.mb-3
                                    i.bi.bi-heart-pulse.me-2
                                    | Default Diet Filters
                                p.text-white-50.small.mb-3 Select the diet restrictions that should be preselected on the suggestion page.
                                if d.dietTags && d.dietTags.length
                                    .row.g-3
                                        each tag in d.dietTags
                                            .col-sm-6
                                                label.app-panel.d-flex.align-items-start.gap-3.h-100(for=`diet-${tag.key}`)
                                                    input.form-check-input.mt-1(
                                                        type="checkbox"
                                                        name="dietTagIds"
                                                        value=tag.id
                                                        id=`diet-${tag.key}`
                                                        checked=tag.selected
                                                    )
                                                    span
                                                        strong.d-block #{tag.label}
                                                        small.text-white-50 #{tag.key}
                                else
                                    p.text-white-50.mb-0 No diet tags are available right now.
                    .d-flex.flex-wrap.gap-2.mt-4
                        button.btn.btn-success(type="submit")
                            i.bi.bi-check-lg.me-1
                            | Save Settings
                        a.btn.btn-outline-light(href="/users/dashboard")
                            i.bi.bi-arrow-left.me-1
                            | Back To Dashboard
