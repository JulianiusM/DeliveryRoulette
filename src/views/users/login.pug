extends ../layout

block meta
    title Login | DeliveryRoulette

block body
    - const hasLocalLogin = !!settings.localLoginEnabled
    - const hasOidcLogin = !!settings.oidcEnabled
    .app-shell.py-3
        section.card.border-0.shadow-lg.overflow-hidden.app-hero-card.is-info
            .card-body.p-4.p-lg-5
                .row.g-4.align-items-end
                    .col-lg-8
                        p.app-eyebrow.mb-2 Account access
                        h1.display-5.fw-semibold.mb-2 Login
                        p.lead.text-white-50.mb-0 Sign in to use personal defaults, favorites, and the full restaurant workflow.
                    .col-lg-4
                        .app-chip-row.justify-content-lg-end
                            if hasLocalLogin
                                span.app-chip Username and password
                            if hasOidcLogin
                                span.app-chip #{settings.oidcName} single sign-on

        section.card.app-section-card
            .card-body
                .row.g-4.justify-content-center
                    .col-xl-6
                        .app-panel.h-100
                            if hasLocalLogin
                                form.row.g-3(action="/users/login" method="post")
                                    +csrf
                                    .col-12
                                        label.form-label(for="username")
                                            i.bi.bi-person-circle.me-1
                                            | Username
                                        input#username.form-control.text-bg-dark(
                                            type="text"
                                            name="username"
                                            maxlength="100"
                                            value=(data && data.username) ? data.username : ''
                                            placeholder="your login name"
                                            required
                                        )
                                    .col-12
                                        label.form-label(for="password")
                                            i.bi.bi-shield-lock.me-1
                                            | Password
                                        input#password.form-control.text-bg-dark(
                                            type="password"
                                            name="password"
                                            minlength="8"
                                            required
                                        )
                                    .col-12.d-flex.flex-wrap.gap-2
                                        button.btn.btn-success(type="submit")
                                            i.bi.bi-box-arrow-in-right.me-1
                                            | Login
                                        a.btn.btn-outline-light(href="/users/forgot-password")
                                            i.bi.bi-key.me-1
                                            | Forgot Password
                            else
                                p.text-white-50.mb-0 Local login is disabled.
                    .col-xl-4
                        .app-panel.h-100
                            h2.h6.text-uppercase.text-white-50.mb-3 Sign-in options
                            .d-flex.flex-column.gap-2
                                if hasOidcLogin
                                    a.btn.btn-primary(href="/users/oidc/login")
                                        i.bi.bi-person-vcard.me-1
                                        | Login using #{settings.oidcName}
                                a.btn.btn-outline-light(href="/users/register")
                                    i.bi.bi-person-plus.me-1
                                    | Create Account
                            p.text-white-50.small.mt-3.mb-0 Use the same account to persist favorites, blocked restaurants, and suggestion defaults.
