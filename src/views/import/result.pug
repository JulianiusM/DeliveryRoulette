extends ../layout

block meta
    title Import Results | DeliveryRoulette

block body
    - const result = (data && data.result) || { restaurants: [], successCount: 0, errorCount: 0 }

    .app-shell.py-3
        section.card.border-0.shadow-lg.overflow-hidden.app-hero-card.is-success
            .card-body.p-4.p-lg-5
                .row.g-4.align-items-end
                    .col-lg-8
                        p.app-eyebrow.mb-2 Import finished
                        h1.display-5.fw-semibold.mb-2 Import Results
                        p.lead.text-white-50.mb-0 Review which restaurants were imported successfully and which ones failed before you continue working.
                    .col-lg-4
                        .row.g-3
                            .col-6
                                .app-stat-card
                                    span.app-stat-label Succeeded
                                    strong.app-stat-value #{result.successCount}
                            .col-6
                                .app-stat-card
                                    span.app-stat-label Failed
                                    strong.app-stat-value #{result.errorCount}
                .d-flex.flex-wrap.gap-2.mt-4
                    a.btn.btn-outline-light(href="/import")
                        i.bi.bi-upload.me-1
                        | Import Another
                    a.btn.btn-outline-light(href="/restaurants")
                        i.bi.bi-shop.me-1
                        | View Restaurants

        if result.restaurants.length === 0
            .app-empty-state
                i.bi.bi-inbox
                p.mb-0 No restaurants were processed.
        else
            section.card.app-section-card
                .card-header
                    i.bi.bi-clipboard-check.me-2
                    | Per-Restaurant Results
                .card-body
                    .app-table-shell.table-responsive
                        table.table.table-dark.table-hover.align-middle
                            thead
                                tr
                                    th Restaurant
                                    th Status
                                    th Details
                            tbody
                                each r in result.restaurants
                                    tr(class=(r.success ? '' : 'table-danger'))
                                        td #{r.name}
                                        td
                                            if r.success
                                                span.badge.text-bg-success
                                                    i.bi.bi-check.me-1
                                                    | Success
                                            else
                                                span.badge.text-bg-danger
                                                    i.bi.bi-x.me-1
                                                    | Failed
                                        td
                                            if r.error
                                                span.text-danger #{r.error}
                                            else
                                                span.text-white-50 Imported successfully
