extends ../layout

block meta
    title Sync Alerts | DeliveryRoulette

block body
    - const alerts = (data && data.alerts) || []
    - const filterType = (data && data.filterType) || ''
    - const filterProvider = (data && data.filterProvider) || ''
    - const filterStatus = (data && data.filterStatus) || 'active'
    - const alertTypes = (data && data.alertTypes) || []
    - const providerKeys = (data && data.providerKeys) || []
    - const activeCount = alerts.filter((alert) => !alert.dismissed).length
    - const dismissedCount = alerts.filter((alert) => alert.dismissed).length

    .app-shell.py-3
        section.card.border-0.shadow-lg.overflow-hidden.app-hero-card.is-danger
            .card-body.p-4.p-lg-5
                .row.g-4.align-items-end
                    .col-lg-8
                        p.app-eyebrow.mb-2 Operational follow-up
                        h1.display-5.fw-semibold.mb-2 Sync Alerts
                        p.lead.text-white-50.mb-0 Review provider drift, stale overrides, and removed restaurants without leaving the app shell.
                    .col-lg-4
                        .row.g-3
                            .col-6
                                .app-stat-card
                                    span.app-stat-label Active
                                    strong.app-stat-value #{activeCount}
                                    small.text-white-50 Alerts needing review in the current view
                            .col-6
                                .app-stat-card
                                    span.app-stat-label Dismissed
                                    strong.app-stat-value #{dismissedCount}
                                    small.text-white-50 Already acknowledged alerts in the current view
                .app-chip-row.mt-4
                    a.btn.btn-outline-light.btn-sm(href="/sync/jobs")
                        i.bi.bi-list-check.me-1
                        | View Sync Jobs
                    a.btn.btn-outline-light.btn-sm(href="/providers")
                        i.bi.bi-plug.me-1
                        | Providers

        section.card.app-section-card
            .card-header
                i.bi.bi-funnel.me-2
                | Filters
            .card-body
                form.row.g-3(method="GET" action="/sync/alerts")
                    .col-md-3
                        label.form-label.text-white-50(for="typeFilter") Alert type
                        select.form-select.text-bg-dark#typeFilter(name="type")
                            option(value="" selected=(filterType === '')) All types
                            each t in alertTypes
                                option(value=t.value selected=(filterType === t.value))= t.label
                    .col-md-3
                        label.form-label.text-white-50(for="providerFilter") Provider
                        select.form-select.text-bg-dark#providerFilter(name="provider")
                            option(value="" selected=(filterProvider === '')) All providers
                            each pk in providerKeys
                                option(value=pk selected=(filterProvider === pk))= pk
                    .col-md-3
                        label.form-label.text-white-50(for="statusFilter") Status
                        select.form-select.text-bg-dark#statusFilter(name="status")
                            option(value="active" selected=(filterStatus === 'active')) Active
                            option(value="dismissed" selected=(filterStatus === 'dismissed')) Dismissed
                            option(value="all" selected=(filterStatus === 'all')) All
                    .col-md-3.d-flex.align-items-end.gap-2
                        button.btn.btn-primary.flex-fill(type="submit")
                            i.bi.bi-funnel.me-1
                            | Apply
                        a.btn.btn-outline-light.flex-fill(href="/sync/alerts")
                            i.bi.bi-arrow-clockwise.me-1
                            | Reset

        if alerts.length > 0 && filterStatus !== 'dismissed'
            section.card.app-section-card
                .card-body.d-flex.justify-content-between.align-items-center.flex-wrap.gap-3
                    p.text-white-50.mb-0 Dismiss all matching alerts once you have reviewed and handled the current filter set.
                    form(method="POST" action="/sync/alerts/dismiss-all")
                        +csrf
                        input(type="hidden" name="type" value=filterType)
                        input(type="hidden" name="provider" value=filterProvider)
                        button.btn.btn-outline-warning(type="submit" onclick="return confirm('Dismiss all matching alerts?')")
                            i.bi.bi-check-all.me-1
                            | Dismiss All

        if alerts.length === 0
            .app-empty-state
                i.bi.bi-bell-slash
                p.mb-0 No alerts match the current filters.
        else
            section.card.app-section-card
                .card-header
                    i.bi.bi-bell.me-2
                    | Alert Feed
                .card-body
                    .d-flex.flex-column.gap-3
                        each a in alerts
                            article.app-list-card(class=a.dismissed ? 'opacity-50' : '')
                                .d-flex.justify-content-between.align-items-start.flex-wrap.gap-3
                                    .flex-grow-1
                                        .d-flex.flex-wrap.align-items-center.gap-2.mb-2
                                            if a.type === 'restaurant_gone'
                                                span.badge.text-bg-danger
                                                    i.bi.bi-shop.me-1
                                                    | Gone
                                            else if a.type === 'menu_changed'
                                                span.badge.text-bg-warning.text-dark
                                                    i.bi.bi-card-list.me-1
                                                    | Menu changed
                                            else if a.type === 'diet_override_stale'
                                                span.badge.text-bg-info.text-dark
                                                    i.bi.bi-heart-pulse.me-1
                                                    | Diet override stale
                                            else
                                                span.badge.text-bg-secondary= a.type
                                            span.badge(class=a.dismissed ? 'text-bg-secondary' : 'text-bg-success') #{a.dismissed ? 'Dismissed' : 'Active'}
                                            span.badge.text-bg-secondary= a.providerKey
                                        h2.h5.mb-1
                                            if a.restaurant
                                                a.link-light.text-decoration-none(href=`/restaurants/${a.restaurantId}`)= a.restaurant.name
                                            else
                                                | #{a.restaurantId}
                                        p.text-white-50.mb-2= a.message
                                        p.text-white-50.small.mb-0 #{new Date(a.createdAt).toLocaleDateString()} #{new Date(a.createdAt).toLocaleTimeString([], {hour: '2-digit', minute: '2-digit'})}
                                    .d-flex.flex-wrap.gap-2
                                        if !a.dismissed
                                            form(method="POST" action=`/sync/alerts/${a.id}/dismiss`)
                                                +csrf
                                                button.btn.btn-sm.btn-outline-warning(type="submit" title="Dismiss")
                                                    i.bi.bi-check-lg.me-1
                                                    | Dismiss
                                        a.btn.btn-sm.btn-outline-light(href=`/restaurants/${a.restaurantId}` title="View restaurant")
                                            i.bi.bi-eye.me-1
                                            | Restaurant
