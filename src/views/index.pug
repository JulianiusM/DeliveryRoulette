extends layout

block meta
    title DeliveryRoulette - Discover your next favorite delivery
    meta(
        name="description"
        content="DeliveryRoulette helps you discover restaurants, manage dietary preferences, and get random delivery suggestions."
    )
    meta(
        name="keywords"
        content="restaurants, delivery, food, suggestions, diet, preferences, lieferando"
    )
    meta(name="author" content="DeliveryRoulette")
    meta(property="og:title" content="DeliveryRoulette - Discover your next favorite delivery")
    meta(
        property="og:description"
        content="Manage restaurants, sync menus from delivery providers, track dietary preferences, and get random suggestions for your team."
    )
    meta(property="og:image" content="/img/logo.png")
    meta(property="og:url" content=settings.rootUrl)
    meta(name="twitter:card" content="summary_large_image")

block body
    - const displayName = user ? (user.displayName || user.name || user.username) : null
    .app-shell.py-3
        section.card.border-0.shadow-lg.overflow-hidden.app-hero-card
            .card-body.p-4.p-lg-5
                .row.g-4.align-items-end
                    .col-lg-7
                        p.app-eyebrow.mb-2 Delivery decision system
                        h1.display-4.fw-semibold.mb-3 DeliveryRoulette
                        if user
                            p.lead.text-white-50.mb-4
                                | Welcome back, 
                                span.text-white #{displayName}
                                | . Your restaurant data, menu intelligence, and suggestion tools are all in one place.
                            .d-flex.flex-wrap.gap-2
                                a.btn.btn-success.btn-lg(href="/suggest")
                                    i.bi.bi-shuffle.me-2
                                    | Suggest A Restaurant
                                a.btn.btn-outline-light.btn-lg(href="/restaurants")
                                    i.bi.bi-shop.me-2
                                    | Browse Restaurants
                        else
                            p.lead.text-white-50.mb-4
                                | Manage restaurant data, sync provider menus, track diet suitability, and generate suggestions that fit the group instead of guessing.
                            .d-flex.flex-wrap.gap-2
                                a.btn.btn-success.btn-lg(href="/users/register")
                                    i.bi.bi-person-plus.me-2
                                    | Create Account
                                a.btn.btn-outline-light.btn-lg(href="/users/login")
                                    i.bi.bi-box-arrow-in-right.me-2
                                    | Log In
                    .col-lg-5
                        .row.g-3
                            .col-6
                                .app-stat-card
                                    span.app-stat-label Core Areas
                                    strong.app-stat-value 6
                                    small.text-white-50 Restaurants, suggestions, imports, sync, diets, docs
                            .col-6
                                .app-stat-card
                                    span.app-stat-label Visibility
                                    strong.app-stat-value Live
                                    small.text-white-50 Availability, favorites, and diet fit stay visible
                            .col-6
                                .app-stat-card
                                    span.app-stat-label Menu Depth
                                    strong.app-stat-value Smart
                                    small.text-white-50 Dedupe, inference, and manual overrides work together
                            .col-6
                                .app-stat-card
                                    span.app-stat-label Workflow
                                    strong.app-stat-value Fast
                                    small.text-white-50 Import, sync, review, and suggest without switching tools

        section.card.app-section-card
            .card-header.d-flex.justify-content-between.align-items-center.flex-wrap.gap-2
                span
                    i.bi.bi-lightning-charge.me-2
                    | Main Routes
                if user
                    a.btn.btn-sm.btn-outline-light(href="/users/dashboard")
                        i.bi.bi-speedometer2.me-1
                        | Your Overview
            .card-body
                .row.g-4
                    .col-md-6.col-xl-3
                        a.app-action-card(href="/restaurants")
                            .d-flex.align-items-center.gap-3
                                span.app-icon-badge.is-primary
                                    i.bi.bi-shop
                                div
                                    h2.h5.mb-1 Restaurants
                                    p.text-white-50.small.mb-0 Inspect menus, diet fit, providers, and visibility.
                            .app-chip-row
                                span.app-chip Shown in app
                                span.app-chip Availability
                                span.app-chip Favorites
                    .col-md-6.col-xl-3
                        a.app-action-card(href="/suggest")
                            .d-flex.align-items-center.gap-3
                                span.app-icon-badge.is-success
                                    i.bi.bi-shuffle
                                div
                                    h2.h5.mb-1 Suggest
                                    p.text-white-50.small.mb-0 Draw from the filtered restaurant pool with real diet thresholds.
                            .app-chip-row
                                span.app-chip Diet thresholds
                                span.app-chip Open now
                                span.app-chip History-aware
                    .col-md-6.col-xl-3
                        a.app-action-card(href="/import")
                            .d-flex.align-items-center.gap-3
                                span.app-icon-badge.is-info
                                    i.bi.bi-upload
                                div
                                    h2.h5.mb-1 Import
                                    p.text-white-50.small.mb-0 Preview bulk data changes before applying them.
                            .app-chip-row
                                span.app-chip JSON and CSV
                                span.app-chip Diff preview
                                span.app-chip Result audit
                    .col-md-6.col-xl-3
                        a.app-action-card(href="/providers")
                            .d-flex.align-items-center.gap-3
                                span.app-icon-badge.is-warning
                                    i.bi.bi-plug
                                div
                                    h2.h5.mb-1 Providers
                                    p.text-white-50.small.mb-0 Run syncs, imports, and maintenance from one place.
                            .app-chip-row
                                span.app-chip Listing discovery
                                span.app-chip Menu import
                                span.app-chip Maintenance jobs

        section.card.app-section-card
            .card-header
                i.bi.bi-grid-1x2-fill.me-2
                | Platform Coverage
            .card-body
                .row.g-4
                    .col-lg-4
                        .app-panel.h-100
                            .d-flex.align-items-center.gap-3.mb-3
                                span.app-icon-badge.is-primary
                                    i.bi.bi-diagram-3
                                div
                                    h2.h5.mb-1 Restaurant Intelligence
                                    p.text-white-50.small.mb-0 Manage real menu data instead of flat restaurant rows.
                            ul.text-white-50.small.mb-0
                                li Search restaurants with fuzzy matching
                                li Inspect provider refs, cuisines, and availability
                                li Review diet suitability from deduped menu items
                                li Edit restaurants, categories, and menu items directly
                    .col-lg-4
                        .app-panel.h-100
                            .d-flex.align-items-center.gap-3.mb-3
                                span.app-icon-badge.is-success
                                    i.bi.bi-heart-pulse
                                div
                                    h2.h5.mb-1 Diet Workflow
                                    p.text-white-50.small.mb-0 Keep diet defaults and heuristic rules aligned.
                            ul.text-white-50.small.mb-0
                                li Per-user diet defaults feed the suggestion page
                                li Global heuristic keyword lists stay editable
                                li Manual item overrides remain possible when heuristics miss
                                li Low-quality matches can be filtered out with score thresholds
                    .col-lg-4
                        .app-panel.h-100
                            .d-flex.align-items-center.gap-3.mb-3
                                span.app-icon-badge.is-info
                                    i.bi.bi-arrow-repeat
                                div
                                    h2.h5.mb-1 Sync And Import
                                    p.text-white-50.small.mb-0 Provider changes and bulk imports stay reviewable.
                            ul.text-white-50.small.mb-0
                                li Listing syncs and direct URL imports
                                li Sync jobs and alerts pages for operational follow-up
                                li Maintenance reruns for heuristics and provider refreshes
                                li Import preview and results for bulk updates

        if !user
            section.card.app-section-card
                .card-body.p-4.p-lg-5.text-center
                    p.app-eyebrow.mb-2 Ready to get started
                    h2.h3.mb-3 Build a restaurant pool your team can actually use
                    p.text-white-50.mb-4 Sign in to save preferences, mark favorites, sync menus, and make suggestions based on real menu coverage.
                    .d-flex.flex-wrap.justify-content-center.gap-2
                        a.btn.btn-success.btn-lg(href="/users/register")
                            i.bi.bi-person-plus.me-2
                            | Create Account
                        a.btn.btn-outline-light.btn-lg(href="/help")
                            i.bi.bi-question-circle.me-2
                            | Read The Guides
