extends ../../layout

block meta
    if data && data.editing
        title Edit Category | DeliveryRoulette
    else
        title New Category | DeliveryRoulette

block body
    - const d = data || {}
    - const editing = d.editing || false
    - const restaurantId = d.restaurantId
    - const formAction = editing ? `/restaurants/${restaurantId}/menu/categories/${d.id}/edit` : `/restaurants/${restaurantId}/menu/categories/new`

    .app-shell.py-3
        section.card.border-0.shadow-lg.overflow-hidden.app-hero-card.is-info
            .card-body.p-4.p-lg-5
                .row.g-4.align-items-end
                    .col-lg-8
                        p.app-eyebrow.mb-2 Menu editor
                        h1.display-5.fw-semibold.mb-2 #{editing ? 'Edit Category' : 'New Category'}
                        p.lead.text-white-50.mb-0 Categories shape menu navigation and grouping on the restaurant detail page.
                    .col-lg-4
                        .app-chip-row.justify-content-lg-end
                            span.app-chip Restaurant #{restaurantId}
                            span.app-chip #{editing ? 'Editing category' : 'Creating category'}

        section.card.app-section-card
            .card-header
                i.bi.bi-list-ul.me-2
                | Category Details
            .card-body
                form(action=formAction method="post")
                    +csrf
                    .row.g-4
                        .col-lg-8
                            .app-panel.h-100
                                .row.g-3
                                    .col-md-8
                                        label.form-label(for="name")
                                            i.bi.bi-list-ul.me-1
                                            | Name
                                        input#name.form-control.text-bg-dark(
                                            type="text"
                                            name="name"
                                            maxlength="150"
                                            value=(d.name || '')
                                            placeholder="Category name"
                                            required
                                        )
                                    .col-md-4
                                        label.form-label(for="sortOrder")
                                            i.bi.bi-sort-numeric-down.me-1
                                            | Sort Order
                                        input#sortOrder.form-control.text-bg-dark(
                                            type="number"
                                            name="sortOrder"
                                            value=(d.sortOrder != null ? d.sortOrder : 0)
                                            placeholder="0"
                                        )
                        .col-lg-4
                            .app-panel.h-100
                                h2.h6.text-uppercase.text-white-50.mb-3 Visibility
                                if editing
                                    .form-check
                                        input#isActive.form-check-input(
                                            type="checkbox"
                                            name="isActive"
                                            checked=d.isActive
                                        )
                                        label.form-check-label(for="isActive") Active
                                else
                                    p.text-white-50.small.mb-0 New categories are added to the menu structure immediately after creation.
                    .d-flex.flex-wrap.gap-2.mt-4
                        button.btn.btn-success(type="submit")
                            i.bi.bi-check-lg.me-1
                            | #{editing ? 'Save Changes' : 'Create Category'}
                        a.btn.btn-outline-light(href=`/restaurants/${restaurantId}`)
                            i.bi.bi-arrow-left.me-1
                            | Back To Restaurant
