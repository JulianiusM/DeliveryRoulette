extends ../../layout

block meta
    if data && data.editing
        title Edit Item | DeliveryRoulette
    else
        title New Item | DeliveryRoulette

block body
    - const d = data || {}
    - const editing = d.editing || false
    - const restaurantId = d.restaurantId
    - const categoryId = d.categoryId
    - const dietTags = d.dietTags || []
    - const formAction = editing ? `/restaurants/${restaurantId}/menu/items/${d.id}/edit` : `/restaurants/${restaurantId}/menu/categories/${categoryId}/items/new`

    .app-shell.py-3
        section.card.border-0.shadow-lg.overflow-hidden.app-hero-card.is-info
            .card-body.p-4.p-lg-5
                .row.g-4.align-items-end
                    .col-lg-8
                        p.app-eyebrow.mb-2 Menu editor
                        h1.display-5.fw-semibold.mb-2 #{editing ? 'Edit Menu Item' : 'New Menu Item'}
                        p.lead.text-white-50.mb-0 Item metadata, allergens, and manual diet overrides all feed the menu intelligence shown on the restaurant page.
                    .col-lg-4
                        .app-chip-row.justify-content-lg-end
                            span.app-chip Restaurant #{restaurantId}
                            if categoryId
                                span.app-chip Category #{categoryId}
                            span.app-chip #{editing ? 'Editing item' : 'Creating item'}

        section.card.app-section-card
            .card-header
                i.bi.bi-cup-hot.me-2
                | Item Details
            .card-body
                form(action=formAction method="post")
                    +csrf
                    .row.g-4
                        .col-lg-7
                            .app-panel.h-100
                                .row.g-3
                                    .col-md-6
                                        label.form-label(for="name")
                                            i.bi.bi-cup-hot.me-1
                                            | Name
                                        input#name.form-control.text-bg-dark(
                                            type="text"
                                            name="name"
                                            maxlength="150"
                                            value=(d.name || '')
                                            placeholder="Item name"
                                            required
                                        )
                                    .col-md-6
                                        label.form-label(for="description")
                                            i.bi.bi-card-text.me-1
                                            | Description
                                        input#description.form-control.text-bg-dark(
                                            type="text"
                                            name="description"
                                            maxlength="500"
                                            value=(d.description || '')
                                            placeholder="Brief description"
                                        )
                                    .col-12
                                        label.form-label(for="allergens")
                                            i.bi.bi-exclamation-triangle.me-1
                                            | Allergens
                                        textarea#allergens.form-control.text-bg-dark(
                                            name="allergens"
                                            rows="3"
                                            maxlength="2000"
                                            placeholder="e.g. gluten, milk, nuts (comma or newline separated)"
                                        )= d.allergens || ''
                                    .col-md-4
                                        label.form-label(for="price")
                                            i.bi.bi-currency-dollar.me-1
                                            | Price
                                        input#price.form-control.text-bg-dark(
                                            type="number"
                                            name="price"
                                            step="0.01"
                                            min="0"
                                            value=(d.price != null ? d.price : '')
                                            placeholder="0.00"
                                        )
                                    .col-md-4
                                        label.form-label(for="currency")
                                            i.bi.bi-cash.me-1
                                            | Currency
                                        input#currency.form-control.text-bg-dark(
                                            type="text"
                                            name="currency"
                                            maxlength="3"
                                            value=(d.currency || '')
                                            placeholder="EUR"
                                        )
                                    .col-md-4
                                        label.form-label(for="sortOrder")
                                            i.bi.bi-sort-numeric-down.me-1
                                            | Sort Order
                                        input#sortOrder.form-control.text-bg-dark(
                                            type="number"
                                            name="sortOrder"
                                            value=(d.sortOrder != null ? d.sortOrder : 0)
                                            placeholder="0"
                                        )
                                    if editing
                                        .col-12
                                            .form-check
                                                input#isActive.form-check-input(
                                                    type="checkbox"
                                                    name="isActive"
                                                    checked=d.isActive
                                                )
                                                label.form-check-label(for="isActive") Active
                        .col-lg-5
                            .app-panel.h-100
                                h2.h5.mb-3
                                    i.bi.bi-heart-pulse.me-2
                                    | Diet Override
                                if dietTags.length > 0
                                    p.text-white-50.small.mb-3 Choose Auto to keep heuristic detection, or set explicit support for this item.
                                    .app-table-shell.table-responsive
                                        table.table.table-dark.table-sm.align-middle
                                            thead
                                                tr
                                                    th Diet tag
                                                    th(style="width: 220px;") Support
                                            tbody
                                                each tag in dietTags
                                                    tr
                                                        td
                                                            strong #{tag.label}
                                                            span.text-white-50.ms-2.small #{tag.key}
                                                        td
                                                            select.form-select.form-select-sm.text-bg-dark(name=`dietOverride[${tag.id}]`)
                                                                option(value="auto" selected=tag.selected === 'auto') Auto
                                                                option(value="true" selected=tag.selected === 'true') Supported
                                                                option(value="false" selected=tag.selected === 'false') Not Supported
                                else
                                    p.text-white-50.small.mb-0 No diet tags are configured yet.
                    .d-flex.flex-wrap.gap-2.mt-4
                        button.btn.btn-success(type="submit")
                            i.bi.bi-check-lg.me-1
                            | #{editing ? 'Save Changes' : 'Add Item'}
                        a.btn.btn-outline-light(href=`/restaurants/${restaurantId}`)
                            i.bi.bi-arrow-left.me-1
                            | Back To Restaurant
