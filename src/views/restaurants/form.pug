extends ../layout

block meta
    if data && data.editing
        title Edit Restaurant | DeliveryRoulette
    else
        title New Restaurant | DeliveryRoulette

block body
    - const d = data || {}
    - const editing = d.editing || false
    - const formAction = editing ? `/restaurants/${d.id}/edit` : '/restaurants/new'

    .app-shell.py-3
        section.card.border-0.shadow-lg.overflow-hidden.app-hero-card
            .card-body.p-4.p-lg-5
                .row.g-4.align-items-end
                    .col-lg-8
                        p.app-eyebrow.mb-2 Restaurant editor
                        h1.display-5.fw-semibold.mb-2 #{editing ? 'Edit Restaurant' : 'New Restaurant'}
                        p.lead.text-white-50.mb-0 Capture the location and visibility data that makes the restaurant appear correctly throughout the app.
                    .col-lg-4
                        .app-chip-row.justify-content-lg-end
                            span.app-chip #{editing ? 'Editing existing record' : 'Creating new record'}
                            if editing
                                span.app-chip ID #{d.id}

        section.card.app-section-card
            .card-header
                i.bi.bi-shop.me-2
                | Restaurant Details
            .card-body
                form(action=formAction method="post")
                    +csrf
                    .row.g-4
                        .col-lg-8
                            .app-panel.h-100
                                .row.g-3
                                    .col-md-6
                                        label.form-label(for="name")
                                            i.bi.bi-shop.me-1
                                            | Name
                                        input#name.form-control.text-bg-dark(
                                            type="text"
                                            name="name"
                                            maxlength="150"
                                            value=(d.name || '')
                                            placeholder="Restaurant name"
                                            required
                                        )
                                    .col-md-6
                                        label.form-label(for="addressLine1")
                                            i.bi.bi-geo-alt.me-1
                                            | Address Line 1
                                        input#addressLine1.form-control.text-bg-dark(
                                            type="text"
                                            name="addressLine1"
                                            maxlength="255"
                                            value=(d.addressLine1 || '')
                                            placeholder="Street and number"
                                            required
                                        )
                                    .col-md-6
                                        label.form-label(for="addressLine2")
                                            i.bi.bi-geo.me-1
                                            | Address Line 2
                                        input#addressLine2.form-control.text-bg-dark(
                                            type="text"
                                            name="addressLine2"
                                            maxlength="255"
                                            value=(d.addressLine2 || '')
                                            placeholder="Apartment, suite, etc."
                                        )
                                    .col-md-4
                                        label.form-label(for="city")
                                            i.bi.bi-building.me-1
                                            | City
                                        input#city.form-control.text-bg-dark(
                                            type="text"
                                            name="city"
                                            maxlength="100"
                                            value=(d.city || '')
                                            placeholder="City"
                                            required
                                        )
                                    .col-md-4
                                        label.form-label(for="postalCode")
                                            i.bi.bi-mailbox.me-1
                                            | Postal Code
                                        input#postalCode.form-control.text-bg-dark(
                                            type="text"
                                            name="postalCode"
                                            maxlength="20"
                                            value=(d.postalCode || '')
                                            placeholder="Postal code"
                                            required
                                        )
                                    .col-md-4
                                        label.form-label(for="country")
                                            i.bi.bi-globe.me-1
                                            | Country
                                        input#country.form-control.text-bg-dark(
                                            type="text"
                                            name="country"
                                            maxlength="100"
                                            value=(d.country || '')
                                            placeholder="Country"
                                        )
                        .col-lg-4
                            .app-panel.h-100
                                h2.h6.text-uppercase.text-white-50.mb-3 Visibility
                                if editing
                                    .form-check.mb-3
                                        input#isActive.form-check-input(
                                            type="checkbox"
                                            name="isActive"
                                            checked=d.isActive
                                        )
                                        label.form-check-label(for="isActive") Shown in app
                                    p.text-white-50.small.mb-0 Controls whether the restaurant appears in DeliveryRoulette lists and suggestions.
                                else
                                    p.text-white-50.small.mb-0 New restaurants are created as visible by default unless the controller applies a different policy.
                    .d-flex.flex-wrap.gap-2.mt-4
                        button.btn.btn-success(type="submit")
                            i.bi.bi-check-lg.me-1
                            | #{editing ? 'Save Changes' : 'Create Restaurant'}
                        a.btn.btn-outline-light(href="/restaurants")
                            i.bi.bi-arrow-left.me-1
                            | Back To Restaurants
